import java.util.*;
public class Main
{
    public void pattern4(int m ,int n){
        for(int i=1;i<=m;i++){
            for(int j=1;j<=i;j++){
                System.out.print(i+" ");
            }
            System.out.println();
        }
    }
	public static void main(String[] args) {
	    Scanner sc=new Scanner(System.in);
	    Main obj=new Main();
	    System.out.print("Enter the number of Rows : ");
	    int m=sc.nextInt();
	    System.out.print("Enter the number of columns : ");
	    int n=sc.nextInt();
	    obj.pattern4(n,m);
	}
}
